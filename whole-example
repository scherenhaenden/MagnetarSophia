                        <div class="text-[10px] text-slate-500 mt-1">~{{ (365 / pace()) | number:'1.1-1' }} exám/año
                        </div>
                    </div>
                    <div class="text-right">
                        <div class="text-xs text-cyan-400 font-bold uppercase tracking-wider">Tendencia Actual</div>
                        <div class="text-2xl font-bold text-cyan-400">{{ recentPace() | number:'1.0-1' }}</div>
                        <div class="text-[10px] text-cyan-500/70 mt-1">~{{ (365 / recentPace()) | number:'1.1-1' }}
                            exám/año</div>
                    </div>
                </div>
                <div class="w-full h-1 bg-slate-800 rounded-full mt-2 overflow-hidden">
                    <div class="bg-gradient-to-r from-slate-600 to-cyan-400 h-full" style="width: 100%"></div>
                </div>
            </div>

            <div class="bg-slate-900 p-5 rounded-2xl shadow-sm border border-slate-800">
                <div class="text-slate-400 text-sm font-medium mb-2">Fecha Final Estimada</div>
                <div class="flex justify-between items-end mb-1">
                    <div>
                        <div class="text-xs text-slate-500">Media Global</div>
                        <div class="text-lg font-bold text-slate-300">{{ projectedDate() | date:'MMM yyyy' }}</div>
                    </div>
                    <div class="text-right">
                        <div class="text-xs text-cyan-400 font-bold uppercase tracking-wider">Según Derivada</div>
                        <div class="text-xl font-bold text-cyan-400">{{ recentProjectedDate() | date:'MMM yyyy' }}</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sección del Gráfico -->
        <div class="bg-slate-900 p-6 rounded-2xl shadow-sm border border-slate-800 relative">
            <h2 class="text-lg font-bold text-white mb-6">Curva de Progreso (Días vs Exámenes)</h2>

            <!-- Leyenda -->
            <div class="flex flex-wrap gap-4 mb-6 text-sm">
                <div class="flex items-center gap-2">
                    <div class="w-3 h-3 rounded-full bg-blue-500"></div><span class="text-slate-300">Progreso
                        Real</span>
                </div>
                <div class="flex items-center gap-2">
                    <div class="w-3 h-3 rounded-full border-2 border-dashed border-cyan-400"></div><span
                        class="text-cyan-400 font-medium">Tendencia Reciente</span>
                </div>
                <div class="flex items-center gap-2">
                    <div class="w-3 h-3 rounded-full border-2 border-dashed border-slate-500"></div><span
                        class="text-slate-400">Promedio Histórico</span>
                </div>
                <div class="flex items-center gap-2">
                    <div class="w-3 h-3 rounded-full bg-emerald-500/40"></div><span class="text-slate-400 text-xs">Ideal
                        3 años</span>
                </div>
                <div class="flex items-center gap-2">
                    <div class="w-3 h-3 rounded-full bg-amber-500/40"></div><span class="text-slate-400 text-xs">Ideal 4
                        años</span>
                </div>
                <div class="flex items-center gap-2">
                    <div class="w-3 h-3 rounded-full bg-orange-500/40"></div><span class="text-slate-400 text-xs">Ideal
                        6 años</span>
                </div>
            </div>

            <!-- Gráfico SVG -->
            <div class="relative w-full aspect-[2/1] min-h-[400px] overflow-visible">
                <svg class="w-full h-full" viewBox="0 0 1000 500" preserveAspectRatio="none">
                    <!-- Líneas de cuadrícula -->
                    @for (level of yAxisLevels(); track level) {
                    <line x1="60" [attr.y1]="getY(level)" x2="960" [attr.y2]="getY(level)" stroke="#334155"
                        stroke-width="1" stroke-dasharray="4" />
                    <text x="50" [attr.y]="getY(level) + 4" text-anchor="end"
                        class="text-xs fill-slate-500 font-mono">{{ level }}</text>
                    }
                    @for (year of xAxisYears(); track year.days) {
                    <line [attr.x1]="getX(year.days)" y1="40" [attr.x2]="getX(year.days)" y2="440" stroke="#334155"
                        stroke-width="1" />
                    <text [attr.x]="getX(year.days)" y="460" text-anchor="middle" class="text-xs fill-slate-400">{{
                        year.label }}</text>
                    }

                    <!-- Ejes -->
                    <line x1="60" y1="440" x2="960" y2="440" stroke="#475569" stroke-width="2" />
                    <line x1="60" y1="40" x2="60" y2="440" stroke="#475569" stroke-width="2" />

                    <!-- Curvas Ideales -->
                    <path [attr.d]="'M ' + getX(0) + ' ' + getY(0) + ' L ' + getX(1095) + ' ' + getY(36)"
                        stroke="#10b981" stroke-width="2" fill="none" opacity="0.25" />
                    <path [attr.d]="'M ' + getX(0) + ' ' + getY(0) + ' L ' + getX(1460) + ' ' + getY(36)"
                        stroke="#f59e0b" stroke-width="2" fill="none" opacity="0.25" />
                    <path [attr.d]="'M ' + getX(0) + ' ' + getY(0) + ' L ' + getX(2190) + ' ' + getY(36)"
                        stroke="#f97316" stroke-width="2" fill="none" opacity="0.25" />

                    <!-- Líneas de Proyección -->
                    <path [attr.d]="projectionPath()" stroke="#64748b" stroke-width="2" stroke-dasharray="6 6"
                        fill="none" />
                    <path [attr.d]="recentProjectionPath()" stroke="#22d3ee" stroke-width="3" stroke-dasharray="8 6"
                        fill="none" />

                    <!-- Línea de Progreso Real -->
                    <path [attr.d]="actualPath()" stroke="#3b82f6" stroke-width="4" stroke-linecap="round"
                        stroke-linejoin="round" fill="none" />

                    <!-- Puntos de Datos -->
                    @for (pt of mappedPoints(); track pt.record.date.getTime()) {
                    <circle [attr.cx]="pt.x" [attr.cy]="pt.y" r="6"
                        class="fill-slate-900 stroke-blue-500 stroke-[3px] cursor-pointer hover:stroke-cyan-400 hover:r-[8px] transition-all duration-200"
                        (mouseenter)="hoverPoint(pt, $event)" (mouseleave)="hoverPoint(null, null)" />
                    }

                    <!-- Puntos de Fin de Proyección -->
                    <circle [attr.cx]="getX(projectedDays())" [attr.cy]="getY(36)" r="5"
                        class="fill-slate-900 stroke-slate-500 stroke-[3px] border-dashed" />
                    <circle [attr.cx]="getX(recentProjectedDays())" [attr.cy]="getY(36)" r="6"
                        class="fill-slate-900 stroke-cyan-400 stroke-[3px] border-dashed" />
                </svg>

                <!-- Tooltip -->
                @if (hoveredData()) {
                <div class="absolute z-10 bg-slate-800 border border-slate-700 text-slate-200 p-3 rounded-lg shadow-2xl text-sm pointer-events-none transform -translate-x-1/2 -translate-y-[120%]"
                    [style.left.px]="tooltipPos().x" [style.top.px]="tooltipPos().y" style="min-width: 220px;">
                    <div class="font-bold text-cyan-400 mb-1 border-b border-slate-700 pb-1">{{
                        hoveredData()?.record?.name }}</div>
                    <div class="grid grid-cols-2 gap-1 mt-2">
                        <div class="text-slate-400 text-[11px]">Fecha:</div>
                        <div class="text-right">{{ hoveredData()?.record?.date | date:'dd.MM.yyyy' }}</div>
                        <div class="text-slate-400 text-[11px]">Examen #:</div>
                        <div class="text-right font-bold text-white">{{ hoveredData()?.record?.examsCount }} / 36</div>
                        <div class="text-slate-400 text-[11px]">Nota:</div>
                        <div class="text-right text-emerald-400 font-bold">{{ hoveredData()?.record?.grade }}</div>
                    </div>
                </div>
                }
            </div>
        </div>

        <!-- Editor JSON -->
        <div class="bg-slate-900 p-6 rounded-2xl shadow-sm border border-slate-800">
            <h2 class="text-lg font-bold text-white mb-2">Editor de Datos (JSON)</h2>
            <div class="bg-slate-800/50 border border-slate-700 rounded-xl p-4 mb-4 text-sm text-slate-400">
                <p>Datos sincronizados con tu último Transcript. Curva de 6 años habilitada.</p>
            </div>
            <textarea #jsonTextarea
                class="w-full h-80 bg-slate-950 text-slate-300 font-mono text-xs p-4 rounded-xl border border-slate-700 focus:border-cyan-500 outline-none resize-none"
                [value]="jsonContent()"></textarea>
            <div class="mt-4 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
                <button (click)="applyJson(jsonTextarea.value)"
                    class="bg-cyan-600 hover:bg-cyan-500 text-white font-medium py-2 px-6 rounded-lg transition-colors">Actualizar
                    Gráfica</button>
                <div class="flex-1">
                    @if (jsonError()) { <span class="text-red-400 bg-red-400/10 px-4 py-2 rounded-lg text-sm">{{
                        jsonError() }}</span> }
                    @if (jsonSuccess()) { <span
                        class="text-emerald-400 bg-emerald-400/10 px-4 py-2 rounded-lg text-sm">¡Gráfica
                        actualizada!</span> }
