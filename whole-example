            <div class="bg-slate-900 p-5 rounded-2xl shadow-sm border border-slate-800">
                <div class="text-slate-400 text-sm font-medium mb-2">Ritmo (Días / Examen)</div>
                <div class="flex justify-between items-end mb-1">
                    <div>
                        <div class="text-xs text-slate-500">Histórico Total</div>
