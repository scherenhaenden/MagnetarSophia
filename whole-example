export class App {
startDate = new Date(2023, 4, 24);

rawRecords = signal<ExamRecord[]>([
    { date: new Date(2023, 11, 9), name: 'Database Modeling (IDBS01)', examsCount: 1, ects: 5, grade: '3,0' },
    { date: new Date(2024, 1, 24), name: 'Software Eng. Principles (IGIS01)', examsCount: 2, ects: 5, grade: '2,0' },
    { date: new Date(2024, 3, 27), name: 'OOP with Java (IOBP01)', examsCount: 3, ects: 5, grade: '2,0' },
    { date: new Date(2024, 5, 8), name: 'Web Application Dev (IPWA01)', examsCount: 4, ects: 5, grade: '1,3' },
    { date: new Date(2024, 9, 18), name: 'Requirements Engineering (IREN01)', examsCount: 5, ects: 5, grade: '1,7' },
    { date: new Date(2025, 0, 3), name: 'Specification (ISPE01)', examsCount: 6, ects: 5, grade: '2,3' },
    { date: new Date(2025, 1, 14), name: 'Software QA (IQSS01)', examsCount: 7, ects: 5, grade: '2,7' },
    { date: new Date(2025, 2, 21), name: 'IT Architecture (IAMG01)', examsCount: 8, ects: 5, grade: '2,3' },
    { date: new Date(2025, 6, 19), name: 'Data Structures (DLBCSDSJCL02)', examsCount: 9, ects: 5, grade: '1,0' },
    { date: new Date(2025, 9, 20), name: 'Prog. Info Systems (IPWA02)', examsCount: 10, ects: 5, grade: '2,0' },
    { date: new Date(2025, 11, 6), name: 'IT-Service Mgmt (IWSM01)', examsCount: 11, ects: 5, grade: '1,0' },
    { date: new Date(2025, 11, 21), name: 'Intro to Academic Work (DLBWIRITT)', examsCount: 12, ects: 5, grade: '2,3' },
    { date: new Date(2026, 0, 29), name: 'Project: Mobile SE (DLBCSEMSE02)', examsCount: 13, ects: 5, grade: '1,0' },
    { date: new Date(2026, 1, 11), name: 'Algorithms & Data Structures (DLBIADPS01)', examsCount: 14, ects: 5, grade:
    '1,0' },
    { date: new Date(2026, 1, 28), name: 'Ethics and Sustainability (DLBSEPENIT)', examsCount: 15, ects: 5, grade: '2,3'
    }
    ]);

    jsonContent = signal<string>('');
        jsonError = signal<string>('');
            jsonSuccess = signal<boolean>(false);

                constructor() {
                this.jsonContent.set(this.generateJson());
                }

                processedRecords = computed(() => {
                const start = this.startDate.getTime();
                return this.rawRecords().map(record => {
                const days = Math.floor((record.date.getTime() - start) / (1000 * 3600 * 24));
                return { ...record, daysFromStart: days };
                });
                });

                currentExams = computed(() => this.processedRecords().length);

                pace = computed(() => {
                const records = this.processedRecords();
                if (records.length === 0) return 0;
                const lastRecord = records[records.length - 1];
                return (lastRecord.daysFromStart || 0) / lastRecord.examsCount;
                });

                recentPace = computed(() => {
                const records = this.processedRecords();
                const n = Math.min(4, records.length - 1);
                if (n <= 0) return this.pace(); const last=records[records.length - 1]; const
                    prev=records[records.length - 1 - n]; return ((last.daysFromStart || 0) - (prev.daysFromStart || 0))
                    / n; }); projectedDays=computed(()=> Math.floor(this.pace() * 36));
                    recentProjectedDays = computed(() => {
                    const records = this.processedRecords();
                    if (records.length === 0) return 0;
                    const last = records[records.length - 1];
                    return (last.daysFromStart || 0) + Math.floor(this.recentPace() * (36 - last.examsCount));
                    });

                    projectedDate = computed(() => {
                    const pDate = new Date(this.startDate.getTime());
                    pDate.setDate(pDate.getDate() + this.projectedDays());
                    return pDate;
                    });

                    recentProjectedDate = computed(() => {
                    const pDate = new Date(this.startDate.getTime());
                    pDate.setDate(pDate.getDate() + this.recentProjectedDays());
                    return pDate;
                    });

                    svgWidth = 1000; svgHeight = 500;
                    margin = { top: 40, right: 40, bottom: 60, left: 60 };
                    innerWidth = this.svgWidth - this.margin.left - this.margin.right;
                    innerHeight = this.svgHeight - this.margin.top - this.margin.bottom;

                    dynamicMaxDays = computed(() => Math.max(2190, Math.max(this.projectedDays(),
                    this.recentProjectedDays()) + 100));
                    getX(days: number): number { return this.margin.left + (days / this.dynamicMaxDays()) *
                    this.innerWidth; }
                    getY(exams: number): number { return (this.margin.top + this.innerHeight) - (exams / 36) *
                    this.innerHeight; }

                    yAxisLevels = computed(() => [0, 6, 12, 18, 24, 30, 36]);
                    xAxisYears = computed(() => {
                    const years = [];
                    const max = this.dynamicMaxDays();
                    for (let d = 365, i = 1; d <= max; d +=365, i++) years.push({ days: d, label: `Año ${i}` }); return
                        years; }); actualPath=computed(()=> {
                        const records = this.processedRecords();
                        if (records.length === 0) return '';
                        let path = `M ${this.getX(0)} ${this.getY(0)}`;
                        for (const r of records) path += ` L ${this.getX(r.daysFromStart || 0)}
                        ${this.getY(r.examsCount)}`;
                        return path;
                        });

                        projectionPath = computed(() => `M ${this.getX(0)} ${this.getY(0)} L
                        ${this.getX(this.projectedDays())} ${this.getY(36)}`);
                        recentProjectionPath = computed(() => {
                        const records = this.processedRecords();
                        if (records.length === 0) return '';
                        const last = records[records.length - 1];
                        return `M ${this.getX(last.daysFromStart || 0)} ${this.getY(last.examsCount)} L
                        ${this.getX(this.recentProjectedDays())} ${this.getY(36)}`;
                        });

                        mappedPoints = computed(() => this.processedRecords().map(r => ({ x: this.getX(r.daysFromStart
                        || 0), y: this.getY(r.examsCount), record: r })));

                        hoveredData = signal<Point | null>(null);
                            tooltipPos = signal({ x: 0, y: 0 });
                            hoverPoint(point: Point | null, event: MouseEvent | null) {
                            this.hoveredData.set(point);
                            if (event && event.target) {
                            const svgContainer = (event.target as
                            Element).closest('.relative')?.getBoundingClientRect();
                            if (svgContainer) this.tooltipPos.set({ x: event.clientX - svgContainer.left, y:
                            event.clientY - svgContainer.top });
                            }
                            }

                            generateJson(): string {
                            return JSON.stringify(this.rawRecords().map(r => ({
                            date: `${r.date.getFullYear()}-${String(r.date.getMonth() + 1).padStart(2,
                            '0')}-${String(r.date.getDate()).padStart(2, '0')}`,
                            name: r.name, examsCount: r.examsCount, ects: r.ects, grade: r.grade
                            })), null, 2);
                            }

                            applyJson(jsonStr: string) {
                            try {
                            this.jsonError.set(''); this.jsonSuccess.set(false);
                            const parsed = JSON.parse(jsonStr);
                            const newRecords = parsed.map((item: any) => {
                            const [y, m, d] = item.date.split('-');
                            return { date: new Date(Number(y), Number(m) - 1, Number(d)), name: item.name, examsCount:
                            Number(item.examsCount), ects: Number(item.ects), grade: String(item.grade) };
                            });
                            newRecords.sort((a, b) => a.date.getTime() - b.date.getTime());
                            this.rawRecords.set(newRecords);
                            this.jsonSuccess.set(true);
                            setTimeout(() => this.jsonSuccess.set(false), 3000);
                            } catch (e: any) { this.jsonError.set('Error en formato JSON. Revisa las comas.'); }
                            }
                            }